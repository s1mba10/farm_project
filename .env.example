# Скопируй в .env и заполни (.env в git не попадает)

# === Локальная разработка (DEV_MODE) ===
# DEV_MODE=true разблокирует:
#   - POST /api/auth/dev-login {name}     — вход без Telegram
#   - POST /api/mock-pay                  — продлить подписку на +7 дней
# В проде всегда false.
DEV_MODE=true

# === Telegram Login Widget ===
# Создай бота у @BotFather, потом:
#   /setdomain  -> укажи farm-test.ru (или localhost для теста; см. README)
# BOT_TOKEN  — токен от BotFather, нужен для проверки подписи виджета
# TG_BOT_USERNAME — username бота без @, фронту нужен для вставки виджета
BOT_TOKEN=
TG_BOT_USERNAME=

# === Админка ===
# Любая длинная строка. Используется в заголовке X-Admin-Token для /api/admin/grant
# (этим эндпоинтом ты вручную выдаёшь подписку после оплаты студента).
ADMIN_TOKEN=

# === Cookie ===
# В проде через https — true. Локально (http://localhost:8080) — false.
COOKIE_SECURE=false
